{
  "name": "vitex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,css,html}\" \"*.ts\" \"*.html\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,css,html}\" \"*.ts\" \"*.html\" \"*.json\" \"*.md\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@11ty/gray-matter": "^2.0.2",
    "@picocss/pico": "^2.1.1",
    "aplayer": "^1.10.1",
    "dayjs": "^1.11.20",
    "highlight.js": "^11.11.0",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.0",
    "vite": "^8.0.10"
  }
}
